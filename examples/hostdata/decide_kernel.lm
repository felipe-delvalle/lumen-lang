# decide_kernel.lm - the host-fed DECISION KERNEL pattern (the codegen seam).
#
# Pattern: a Lumen kernel is the decision AUTHORITY inside a live loop whose
# transport still lives on the host (network fetch, auth). The host:
#   1. fetches live data,
#   2. APPENDS a generated main() with the data embedded as literal calls
#      (Lumen has no stdin/file data path yet - that gap is tracked friction),
#   3. runs the program (interpreter for latency, native for throughput),
#   4. token-walk parses the emitted records (CLI stdout is newline-less),
#   5. RE-COMPUTES every decision itself and HALTS on any disagreement.
# Step 5 is the point: the host is not trusted to decide, and the kernel is
# not trusted silently - every live iteration is a two-implementation proof.
#
# This file is self-contained and runnable (the demo main stands in for the
# host's generated one). A real deployment ships the kernel WITHOUT main and
# concatenates the generated main at run time.
#
# Expected output (one DEC record per item, then DONE):
#   DEC 0 140 1  DEC 1 45 0  DEC 2 90 1  DONE
# (item 1 fails the gate: score 45 < threshold 60)

fn score(value: Int, weight: Int) -> Int {
  return value * weight / 10
}

fn emit_dec(idx: Int, s: Int, gate: Int) -> Int {
  var line: Text = "DEC "
  line = text_concat(line, int_to_text(idx))
  line = text_concat(line, " ")
  line = text_concat(line, int_to_text(s))
  line = text_concat(line, " ")
  line = text_concat(line, int_to_text(gate))
  console.print(line)
  return 0
}

fn decide(idx: Int, value: Int, weight: Int, threshold: Int) -> Int {
  let s: Int = score(value, weight)
  var gate: Int = 0
  if s >= threshold {
    gate = 1
  }
  return emit_dec(idx, s, gate)
}

# In production this main is GENERATED by the host with live data embedded.
fn main() -> Int {
  let threshold: Int = 60
  let a: Int = decide(0, 70, 20, threshold)
  let b: Int = decide(1, 15, 30, threshold)
  let c: Int = decide(2, 60, 15, threshold)
  console.print("DONE")
  return 0
}
